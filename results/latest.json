                      "settings": {
                        "html": "<div id=\"bmiil-hdr\" style=\"font-family:'DM Sans',sans-serif;position:sticky;top:0;left:0;right:0;z-index:9999;display:flex;flex-direction:column;\">\n\n<!-- NAV BAR -->\n<nav id=\"bmiil-nav\" style=\"height:70px;padding:0 2.5rem;display:flex;align-items:center;justify-content:space-between;background:#08122A;border-bottom:1px solid rgba(196,154,42,0.15);position:relative;overflow:visible;\">\n\n  <!-- Logo -->\n  <a href=\"https://bmiil.com/\" style=\"display:flex;align-items:center;gap:14px;text-decoration:none;flex-shrink:0;\">\n    <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/BMIIL-LOGO.png\" alt=\"BMIIL\"\n         style=\"width:48px;height:48px;object-fit:contain;display:block;flex-shrink:0;\">\n    <div style=\"display:flex;flex-direction:column;line-height:1;\">\n      <span style=\"font-family:'DM Sans',sans-serif;font-size:1.0rem;font-weight:700;color:#FFFFFF;letter-spacing:0.06em;text-transform:uppercase;line-height:1.25;display:block;\">Bareilly Medtech</span>\n      <span style=\"font-family:'DM Sans',sans-serif;font-size:0.58rem;font-weight:700;color:#FFFFFF;letter-spacing:0.06em;text-transform:uppercase;display:block;line-height:1.25;margin-top:3px;\">Incubation &amp; Innovation Labs</span>\n    </div>\n  </a>\n\n  <!-- Desktop menu \u2014 filled by WP nav injection -->\n  <div id=\"bmiil-desktop-slot\" style=\"display:flex;align-items:center;overflow:visible;\"></div>\n\n  <!-- Hamburger -->\n  <button id=\"bmiil-hamburger\" onclick=\"bmiilToggle()\" aria-label=\"Menu\" aria-expanded=\"false\"\n    style=\"display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;\">\n    <span style=\"display:block;width:24px;height:2px;background:#FFFFFF;border-radius:1px;\"></span>\n    <span style=\"display:block;width:24px;height:2px;background:#FFFFFF;border-radius:1px;\"></span>\n    <span style=\"display:block;width:24px;height:2px;background:#FFFFFF;border-radius:1px;\"></span>\n  </button>\n</nav>\n\n<!-- ANNOUNCEMENT BAR -->\n<div id=\"bmiil-ann\" style=\"background:#C49A2A;padding:0.45rem 2.5rem;display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap;\">\n  <p style=\"font-size:12px;font-weight:500;color:#08122A;letter-spacing:0.03em;margin:0;\">\n    &#127945; <strong style=\"font-weight:700;\">Cohort 1 Applications Open</strong> &#8212; Limited seats available for our inaugural Medtech Incubation Program.\n  </p>\n  <a href=\"https://test.bmiil.com/apply/\" style=\"font-size:12px;font-weight:700;color:#08122A;text-decoration:underline;white-space:nowrap;\">Apply Before August 31 &#8594;</a>\n  <button onclick=\"document.getElementById('bmiil-ann').style.display='none'\"\n    style=\"background:none;border:none;cursor:pointer;color:#08122A;font-size:0.95rem;opacity:0.55;padding:0;line-height:1;flex-shrink:0;\">&#10005;</button>\n</div>\n\n</div><!-- sticky wrapper end -->\n\n<!-- MOBILE MENU (outside sticky so it pushes content naturally) -->\n<div id=\"bmiil-mob\" style=\"display:none;background:rgba(8,18,42,0.98);border-bottom:1px solid rgba(196,154,42,0.15);padding:1.2rem 2.5rem 1.8rem;position:relative;z-index:9998;\">\n  <div id=\"bmiil-mob-slot\">\n    <ul style=\"list-style:none;margin:0;padding:0;\">\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/programs/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">Programs</a></li>\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/about/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">About BIU</a></li>\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/team/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">Team</a></li>\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/latest-events/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">News &amp; Events</a></li>\n      <li style=\"padding-top:1rem;\"><a href=\"https://test.bmiil.com/investor-deck/\" style=\"background:#C49A2A;color:#08122A;font-weight:600;padding:10px 22px;border-radius:2px;text-decoration:none;display:inline-block;\">Investor Deck &#8594;</a></li>\n    </ul>\n  </div>\n</div>\n\n<style>\n/* \u2500\u2500 NAV LINKS \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.bmiil-nm { display:flex!important;align-items:center;gap:2rem;list-style:none!important;margin:0!important;padding:0!important; }\n.bmiil-nm > li { position:relative;list-style:none!important; }\n.bmiil-nm > li > a {\n  font-family:'DM Sans',sans-serif;font-size:13px;color:rgba(255,255,255,0.65)!important;\n  text-decoration:none!important;letter-spacing:0.05em;white-space:nowrap;\n  display:block;padding:0;line-height:70px;background:none!important;transition:color .2s;\n}\n.bmiil-nm > li > a:hover { color:#E2BF68!important; }\n.bmiil-nm > li.current-menu-item > a,\n.bmiil-nm > li.current-page-ancestor > a { color:#C49A2A!important; }\n/* CTA */\n.bmiil-nm > li:last-child > a, .bmiil-nm > li.nav-cta > a {\n  background:#C49A2A!important;color:#08122A!important;font-weight:600;\n  padding:9px 22px!important;border-radius:2px;letter-spacing:0.04em;line-height:normal;\n}\n.bmiil-nm > li:last-child > a:hover, .bmiil-nm > li.nav-cta > a:hover { background:#E2BF68!important; }\n/* Dropdown arrow */\n.bmiil-nm > li.menu-item-has-children > a::after { content:\" \u25be\";font-size:9px;opacity:0.4;margin-left:2px; }\n/* \u2500\u2500 DROPDOWN \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.bmiil-nm > li > .sub-menu, .bmiil-nm > li > ul {\n  visibility:hidden;opacity:0;pointer-events:none;\n  position:absolute;top:100%;left:0;z-index:10000;\n  min-width:220px;background:#0F1F45;\n  border:1px solid rgba(196,154,42,0.25);border-top:2px solid #C49A2A;\n  border-radius:0 4px 4px 4px;padding:6px 0;\n  box-shadow:0 12px 40px rgba(0,0,0,0.65);\n  list-style:none!important;margin:0;\n  transition:opacity .15s,visibility .15s,transform .15s;transform:translateY(4px);\n}\n.bmiil-nm > li > .sub-menu::before, .bmiil-nm > li > ul::before {\n  content:\"\";position:absolute;top:-12px;left:0;right:0;height:12px;background:transparent;\n}\n.bmiil-nm > li:hover > .sub-menu, .bmiil-nm > li:hover > ul,\n.bmiil-nm > li:focus-within > .sub-menu, .bmiil-nm > li:focus-within > ul {\n  visibility:visible;opacity:1;pointer-events:auto;transform:translateY(0);\n}\n.bmiil-nm .sub-menu li, .bmiil-nm > li > ul li { list-style:none!important;border-bottom:1px solid rgba(255,255,255,0.05); }\n.bmiil-nm .sub-menu li:last-child, .bmiil-nm > li > ul li:last-child { border-bottom:none; }\n.bmiil-nm .sub-menu li a, .bmiil-nm > li > ul li a {\n  font-family:'DM Sans',sans-serif!important;font-size:13px!important;\n  color:rgba(255,255,255,0.65)!important;background:transparent!important;\n  padding:11px 20px!important;display:block;white-space:nowrap;\n  font-weight:400!important;line-height:normal;text-decoration:none!important;\n  transition:background .12s,color .12s,padding-left .12s;\n}\n.bmiil-nm .sub-menu li a:hover, .bmiil-nm > li > ul li a:hover {\n  color:#E2BF68!important;background:rgba(196,154,42,0.1)!important;padding-left:26px!important;\n}\n/* \u2500\u2500 MOBILE \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n@media(max-width:900px){\n  #bmiil-desktop-slot { display:none!important; }\n  #bmiil-hamburger { display:flex!important; }\n  .bmiil-nm { flex-direction:column!important;gap:0!important;align-items:flex-start!important; }\n  .bmiil-nm > li { width:100%; }\n  .bmiil-nm > li > a { padding:0.8rem 0!important;font-size:15px!important;line-height:normal!important;color:rgba(255,255,255,0.8)!important;border-bottom:1px solid rgba(255,255,255,0.07); }\n  .bmiil-nm > li > .sub-menu, .bmiil-nm > li > ul {\n    position:static!important;visibility:hidden;opacity:0;max-height:0;overflow:hidden;\n    transform:none!important;box-shadow:none!important;border:none!important;\n    border-left:2px solid rgba(196,154,42,0.3)!important;border-radius:0!important;\n    margin:0 0 0 1rem;background:rgba(255,255,255,0.03)!important;\n    transition:opacity .2s,max-height .25s,visibility .2s;padding:0!important;\n  }\n  .bmiil-nm > li.open > .sub-menu, .bmiil-nm > li.open > ul {\n    visibility:visible!important;opacity:1!important;max-height:400px!important;pointer-events:auto!important;\n  }\n  .bmiil-nm > li:hover > .sub-menu, .bmiil-nm > li:hover > ul { visibility:hidden;opacity:0;pointer-events:none; }\n}\n</style>\n\n<script>\n(function(){\n  function inject(){\n    var src=document.getElementById('bmiil-nav-data');\n    if(!src)return;\n    var m=src.querySelector('ul');\n    if(!m)return;\n    m.className='bmiil-nm';\n    // Desktop\n    var ds=document.getElementById('bmiil-desktop-slot');\n    if(ds){ds.innerHTML='';ds.appendChild(m.cloneNode(true));}\n    // Mobile\n    var ms=document.getElementById('bmiil-mob-slot');\n    if(ms){ms.innerHTML='';var mc=m.cloneNode(true);mc.className='bmiil-nm';ms.appendChild(mc);}\n    // Active link highlight\n    var p=window.location.pathname;\n    document.querySelectorAll('.bmiil-nm a').forEach(function(a){\n      var h=a.getAttribute('href')||'';\n      if(h!=='/'&&h!==''&&p.startsWith(h))a.style.color='#C49A2A';\n    });\n  }\n  window.bmiilToggle=function(){\n    var m=document.getElementById('bmiil-mob');\n    var o=m.style.display==='block';\n    m.style.display=o?'none':'block';\n    document.getElementById('bmiil-hamburger').setAttribute('aria-expanded',String(!o));\n  };\n  function initMob(){\n    if(window.innerWidth>900)return;\n    document.querySelectorAll('.bmiil-nm>li.menu-item-has-children>a').forEach(function(a){\n      a.addEventListener('click',function(e){\n        var li=this.closest('li'),op=li.classList.contains('open');\n        document.querySelectorAll('.bmiil-nm>li').forEach(function(el){el.classList.remove('open');});\n        if(!op){e.preventDefault();li.classList.add('open');}\n      });\n    });\n  }\n  document.addEventListener('click',function(e){\n    if(!e.target.closest('.bmiil-nm'))\n      document.querySelectorAll('.bmiil-nm>li').forEach(function(el){el.classList.remove('open');});\n  });\n  window.addEventListener('scroll',function(){\n    var n=document.getElementById('bmiil-nav');\n    if(n)n.style.background=window.scrollY>10?'rgba(8,18,42,0.99)':'#08122A';\n  },{passive:true});\n  if(document.readyState==='loading'){\n    document.addEventListener('DOMContentLoaded',function(){inject();initMob();});\n  }else{inject();initMob();}\n})();\n</script>"
