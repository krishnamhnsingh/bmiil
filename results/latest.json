                      "id": "3a6ea273",
                      "elType": "widget",
                      "settings": {
                        "html": "\n<div style=\"background:#08122A;padding:160px 0 64px;border-bottom:1px solid rgba(196,154,42,0.15);position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;\"></div>\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;position:relative;z-index:1;\">\n    <div style=\"font-family:DM Mono;font-size:10px;color:rgba(255,255,255,0.3);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:3rem;\">\n      <a href=\"/\" style=\"color:rgba(255,255,255,0.3);text-decoration:none;\">Home</a>\n      <span style=\"opacity:.4;\"> / </span>\n      <span style=\"color:#C49A2A;\">Team &amp; Leadership</span>\n    </div>\n    <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:1.8rem;\">\n      <div style=\"width:40px;height:1px;background:#C49A2A;flex-shrink:0;\"></div>\n      <span style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;\">The People Behind the Mission</span>\n    </div>\n    <h1 style=\"font-family:Cormorant Garamond;font-size:clamp(2.5rem,5vw,5rem);font-weight:300;line-height:1.04;color:#FFFFFF;margin:0 0 1.5rem;\">\n      Built by people who know<br>the problem <em style=\"font-style:italic;color:#E2BF68;\">from the inside.</em>\n    </h1>\n    <p style=\"font-size:1rem;line-height:1.7;color:rgba(255,255,255,0.5);max-width:600px;margin:0;\">BMIIL is led by clinicians, technology entrepreneurs, and institution builders \u2014 people who have spent careers inside India's healthcare system and know exactly where it breaks down.</p>\n  </div>\n</div>\n\n<div style=\"background:#F7F3EC;padding:7rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;\">\n\n    <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">Founders &amp; Board</p>\n    <h2 style=\"font-family:Cormorant Garamond;font-size:2rem;font-weight:300;color:#08122A;margin:0 0 2.5rem;\">The founding leadership.</h2>\n\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-bottom:5rem;\">\n      <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;overflow:hidden;\">\n  <div style=\"background:#08122A;padding:2.5rem 2rem;text-align:center;position:relative;overflow:hidden;\">\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;\"></div>\n    <div style=\"width:110px;height:110px;border-radius:50%;border:3px solid rgba(196,154,42,0.4);margin:0 auto 1.2rem;overflow:hidden;background:#0F1F45;position:relative;z-index:1;\">\n      <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/Dr.-Varun-Agarwal.webp\" alt=\"Dr. Varun Agarwal\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n    </div>\n    <div style=\"font-family:Cormorant Garamond;font-size:1.3rem;font-weight:700;color:#FFFFFF;margin-bottom:0.3rem;position:relative;z-index:1;\">Dr. Varun Agarwal</div>\n    <div style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#C49A2A;position:relative;z-index:1;\">Founder &amp; Advisory Board Member</div>\n  </div>\n  <div style=\"padding:1.8rem 2rem;\">\n    <div style=\"font-size:11px;color:#7A8BA8;margin-bottom:1rem;font-family:DM Mono;letter-spacing:0.05em;\">MBBS \u00b7 MD Orthopaedics &amp; Spine Surgery</div>\n    <p style=\"font-size:13px;line-height:1.75;color:#4A5C78;margin:0 0 1.5rem;\">A practicing spine surgeon and President of the UP Spine Surgeons Association, Dr. Varun brings the rarest combination in medtech \u2014 deep clinical knowledge and an entrepreneur's instinct for where the system fails patients.</p>\n    <a href=\"#\" style=\"font-size:12px;color:#C49A2A;text-decoration:none;font-weight:500;\">Connect on LinkedIn \u2192</a>\n  </div>\n</div><div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;overflow:hidden;\">\n  <div style=\"background:#08122A;padding:2.5rem 2rem;text-align:center;position:relative;overflow:hidden;\">\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;\"></div>\n    <div style=\"width:110px;height:110px;border-radius:50%;border:3px solid rgba(196,154,42,0.4);margin:0 auto 1.2rem;overflow:hidden;background:#0F1F45;position:relative;z-index:1;\">\n      <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/drarjunagarwal.webp\" alt=\"Dr. Arjun Agarwal\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n    </div>\n    <div style=\"font-family:Cormorant Garamond;font-size:1.3rem;font-weight:700;color:#FFFFFF;margin-bottom:0.3rem;position:relative;z-index:1;\">Dr. Arjun Agarwal</div>\n    <div style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#C49A2A;position:relative;z-index:1;\">Co-founder &amp; Advisory Board Member</div>\n  </div>\n  <div style=\"padding:1.8rem 2rem;\">\n    <div style=\"font-size:11px;color:#7A8BA8;margin-bottom:1rem;font-family:DM Mono;letter-spacing:0.05em;\">Medical Professional \u00b7 BIU Faculty</div>\n    <p style=\"font-size:13px;line-height:1.75;color:#4A5C78;margin:0 0 1.5rem;\">Co-founder and advisory board member of BMIIL, bringing deep medical expertise and institutional knowledge from Bareilly International University to guide the incubator's clinical strategy.</p>\n    <a href=\"#\" style=\"font-size:12px;color:#C49A2A;text-decoration:none;font-weight:500;\">Connect on LinkedIn \u2192</a>\n  </div>\n</div><div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;overflow:hidden;\">\n  <div style=\"background:#08122A;padding:2.5rem 2rem;text-align:center;position:relative;overflow:hidden;\">\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;\"></div>\n    <div style=\"width:110px;height:110px;border-radius:50%;border:3px solid rgba(196,154,42,0.4);margin:0 auto 1.2rem;overflow:hidden;background:#0F1F45;position:relative;z-index:1;\">\n      <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/claudius-e1761136422449.webp\" alt=\"Claudius Lazarus\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n    </div>\n    <div style=\"font-family:Cormorant Garamond;font-size:1.3rem;font-weight:700;color:#FFFFFF;margin-bottom:0.3rem;position:relative;z-index:1;\">Claudius Lazarus</div>\n    <div style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#C49A2A;position:relative;z-index:1;\">Co-founder &amp; CEO</div>\n  </div>\n  <div style=\"padding:1.8rem 2rem;\">\n    <div style=\"font-size:11px;color:#7A8BA8;margin-bottom:1rem;font-family:DM Mono;letter-spacing:0.05em;\">Technology Entrepreneur \u00b7 25+ Years</div>\n    <p style=\"font-size:13px;line-height:1.75;color:#4A5C78;margin:0 0 1.5rem;\">With over 25 years building and scaling technology startups across the US, Europe, and India, Claudius brings the operational and strategic firepower to turn BMIIL's vision into an institution.</p>\n    <a href=\"#\" style=\"font-size:12px;color:#C49A2A;text-decoration:none;font-weight:500;\">Connect on LinkedIn \u2192</a>\n  </div>\n</div>\n    </div>\n\n    <p style=\"display:inli