1.5rem;text-align:center;\">\n    <a href=\"https://www.linkedin.com/in/meenal-vaish-b7656a304\" target=\"_blank\" rel=\"noopener\" style=\"font-size:12px;color:#C49A2A;text-decoration:none;font-weight:500;display:inline-flex;align-items:center;gap:6px;\">\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#C49A2A\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z\"/></svg>\n      Connect on LinkedIn\n    </a>\n  </div>\n</div>\n      <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;overflow:hidden;position:relative;\">\n  <div style=\"position:absolute;top:0;left:0;right:0;height:3px;background:#C49A2A;\"></div>\n  <div style=\"background:#08122A;padding:2rem 1.5rem;text-align:center;position:relative;overflow:hidden;\">\n    <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;\"></div>\n    <div style=\"width:90px;height:90px;border-radius:50%;border:2px solid rgba(196,154,42,0.35);margin:0 auto 1rem;overflow:hidden;background:#0F1F45;position:relative;z-index:1;\">\n      <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/SURABHI-CHATERJEE.png\" alt=\"Surabhi Chatterjee\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n    </div>\n    <div style=\"font-family:Cormorant Garamond;font-size:1.15rem;font-weight:700;color:#FFFFFF;margin-bottom:0.3rem;position:relative;z-index:1;\">Surabhi Chatterjee</d