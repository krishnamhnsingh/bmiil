              "settings": {
                "html": "<footer style=\"background:#050D1C;padding:4rem 0 2.5rem;border-top:1px solid rgba(196,154,42,0.15);font-family:DM Sans;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;\">\n\n    <!-- TOP GRID -->\n    <div style=\"display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem;padding-bottom:3rem;border-bottom:1px solid rgba(255,255,255,0.06);\">\n\n      <!-- Brand -->\n      <div>\n        <div style=\"display:flex;align-items:center;gap:14px;margin-bottom:1.2rem;\">\n          <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/BAREILLY-MEDTECH-Logo-1-scaled-e1775563234930.webp\" alt=\"BMIIL Logo\" style=\"width:52px;height:52px;object-fit:contain;flex-shrink:0;display:block;\">\n          <strong style=\"font-family:Cormorant Garamond;font-size:1.3rem;color:#FFFFFF;letter-spacing:0.04em;\">BMIIL</strong>\n        </div>\n        <p style=\"font-size:13px;line-height:1.7;color:rgba(255,255,255,0.35);margin:0 0 1.2rem;\">Building the next generation of healthcare innovators from the heart of North India.</p>\n        <address style=\"font-size:12px;line-height:1.7;color:rgba(255,255,255,0.3);font-style:normal;\">\n          Bareilly International University<br>\n          Pilibhit Bypass Road, Bareilly \u2014 243006<br>\n          Uttar Pradesh, India<br><br>\n          <a href=\"mailto:info@bmiil.com\" style=\"color:#C49A2A;text-decoration:none;\">info@bmiil.com</a>\n        </address>\n      </div>\n\n      <!-- Programs -->\n      <div>\n        <h4 style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;margin:0 0 1.2rem;\">Programs</h4>\n        <ul style=\"list-style:none;padding:0;margin:0;\">\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/programs/medtech-incubation/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Medtech Incubation</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/programs/accelerator/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Accelerator Program</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/programs/ayush/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Ayush Incubation</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/apply/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Apply Now</a></li>\n        </ul>\n      </div>\n\n      <!-- Resources -->\n      <div>\n        <h4 style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;margin:0 0 1.2rem;\">Resources</h4>\n        <ul style=\"list-style:none;padding:0;margin:0;\">\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/apply/#process\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Application Process</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/programs/#labs\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Lab Facilities</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/programs/#mentors\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Mentorship Network</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/programs/#regulatory\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Regulatory Guidance</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/investors/#grants\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Grants & Funding</a></li>\n        </ul>\n      </div>\n\n      <!-- Company -->\n      <div>\n        <h4 style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;margin:0 0 1.2rem;\">Company</h4>\n        <ul style=\"list-style:none;padding:0;margin:0;\">\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/about/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">About Us</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/investors/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Partners & Investors</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/news/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">News & Events</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/careers/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Careers</a></li>\n          <li style=\"margin-bottom:0.7rem;\"><a href=\"/contact/\" style=\"font-size:13px;color:rgba(255,255,255,0.4);text-decoration:none;\">Contact</a></li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- BOTTOM BAR -->\n    <div style=\"display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;\">\n      <p style=\"font-size:11px;color:rgba(255,255,255,0.2);margin:0;\">\u00a9 2026 BMIIL. Hosted by <a href=\"https://biu.edu.in\" target=\"_blank\" style=\"color:#C49A2A;text-decoration:none;\">Bareilly International University</a>. All rights reserved.</p>\n      <div style=\"display:flex;gap:1rem;\">\n        <a href=\"#\" style=\"width:32px;height:32px;border-radius:2px;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.35);font-size:11px;text-decoration:none;font-weight:600;\">in</a>\n        <a href=\"#\" style=\"width:32px;height:32px;border-radius:2px;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.35);font-size:13px;text-decoration:none;\">\ud835\udd4f</a>\n        <a href=\"mailto:info@bmiil.com\" style=\"width:32px;height:32px;border-radius:2px;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.35);font-size:13px;text-decoration:none;\">\u2709</a>\n      </div>\n    </div>\n\n  </div>\n</footer>",
