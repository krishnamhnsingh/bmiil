              "settings": {
                "html": "<div style=\"font-family:DM Sans,sans-serif;\">\n\n<div id=\"bmiil-header-wrap\" style=\"position:sticky;top:0;left:0;right:0;z-index:9999;display:flex;flex-direction:column;\">\n\n<nav id=\"bmiil-nav\" style=\"height:70px;padding:0 2.5rem;display:flex;align-items:center;justify-content:space-between;background:#08122A;border-bottom:1px solid rgba(196,154,42,0.15);position:relative;overflow:visible;\">\n  <a href=\"/\" style=\"display:flex;align-items:center;gap:14px;text-decoration:none;flex-shrink:0;\"><img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/BMIIL-LOGO.png\" alt=\"BMIIL Logo\" style=\"width:56px;height:56px;object-fit:contain;flex-shrink:0;display:block;\"><div style=\"display:flex;flex-direction:column;line-height:1;\"><strong style=\"font-family:Cormorant Garamond,serif;font-size:1.25rem;font-weight:700;color:#FFFFFF;letter-spacing:0.04em;line-height:1.15;\">BMIIL</strong><span style=\"font-family:DM Mono,monospace;font-size:0.62rem;color:#C49A2A;letter-spacing:0.18em;text-transform:uppercase;margin-top:3px;\">Medtech Incubation</span></div></a>\n  <div id=\"bmiil-menu-container\" style=\"display:flex;align-items:center;\"><div id=\"bmiil-desktop-menu-slot\"></div></div>\n  <button id=\"bmiil-hamburger\" onclick=\"bmiilToggleMenu()\" style=\"display:none;flex-direction:column;justify-content:space-between;width:26px;height:18px;background:none;border:none;cursor:pointer;padding:0;\" aria-label=\"Open menu\" aria-expanded=\"false\"><span style=\"display:block;width:100%;height:2px;background:#FFFFFF;\"></span><span style=\"display:block;width:100%;height:2px;background:#FFFFFF;\"></span><span style=\"display:block;width:100%;height:2px;background:#FFFFFF;\"></span></button>\n</nav>\n\n<div id=\"bmiil-announce\" style=\"background:#C49A2A;padding:0.45rem 2.5rem;display:flex;align-items:center;justify-content:center;gap:1.5rem;\">\n  <p style=\"font-size:12px;font-weight:500;color:#08122A;letter-spacing:0.04em;margin:0;white-space:nowrap;\">\ud83c\udfc9 <strong style=\"font-weight:700;\">Cohort 1 Applications Open</strong> \u2014 Limited seats available for our inaugural Medtech Incubation Program.</p>\n  <a href=\"/apply/\" style=\"font-size:12px;font-weight:700;color:#08122A;text-decoration:underline;white-space:nowrap;\">Apply Before March 31 \u2192</a>\n  <button onclick=\"document.getElementById('bmiil-announce').style.display='none'\" style=\"background:none;border:none;cursor:pointer;color:#08122A;font-size:0.9rem;opacity:0.55;margin-left:0.5rem;line-height:1;padding:0;flex-shrink:0;\">\u2715</button>\n</div>\n\n</div>\n\n<div id=\"bmiil-mobile-menu\" style=\"display:none;background:rgba(8,18,42,0.98);border-bottom:1px solid rgba(196,154,42,0.15);padding:1.5rem 2.5rem 2rem;\"><div id=\"bmiil-mobile-menu-slot\"><ul class=\"bmiil-nav-menu\" style=\"list-style:none;margin:0;padding:0;\"><li style=\"border-bottom:1px solid rgba(255,255,255,0.06);\"><a href=\"/programs/\" style=\"display:block;padding:0.85rem 0;font-size:15px;color:rgba(255,255,255,0.75);text-decoration:none;\">Programs</a></li><li style=\"border-bottom:1px solid rgba(255,255,255,0.06);\"><a href=\"/about/\" style=\"display:block;padding:0.85rem 0;font-size:15px;color:rgba(255,255,255,0.75);text-decoration:none;\">About BIU</a></li><li style=\"border-bottom:1px solid rgba(255,255,255,0.06);\"><a href=\"/team/\" style=\"display:block;padding:0.85rem 0;font-size:15px;color:rgba(255,255,255,0.75);text-decoration:none;\">Team</a></li><li style=\"border-bottom:1px solid rgba(255,255,255,0.06);\"><a href=\"/news/\" style=\"display:block;padding:0.85rem 0;font-size:15px;color:rgba(255,255,255,0.75);text-decoration:none;\">News</a></li><li style=\"padding-top:1rem;\"><a href=\"/investors/\" style=\"background:#C49A2A;color:#08122A;font-weight:600;padding:10px 20px;border-radius:2px;text-decoration:none;display:inline-block;\">Investor Deck \u2192</a></li></ul></div></div>\n\n<style>\n#bmiil-nav a{transition:color .2s}\n.bmiil-nav-menu{display:flex !important;align-items:center;gap:2rem;list-style:none !important;margin:0 !important;padding:0 !important}\n.bmiil-nav-menu>li{position:relative;list-style:none !important}\n.bmiil-nav-menu>li>a{font-family:DM Sans,sans-serif;font-size:13px;color:rgba(255,255,255,0.65) !important;text-decoration:none !important;letter-spacing:0.05em;white-space:nowrap;display:block;padding:0;line-height:70px;background:none !important;transition:color .2s}\n.bmiil-nav-menu>li>a:hover{color:#E2BF68 !important}\n.bmiil-nav-menu>li.current-menu-item>a,.bmiil-nav-menu>li.current-page-ancestor>a{color:#C49A2A !important}\n.bmiil-nav-menu>li:last-child>a,.bmiil-nav-menu>li.nav-cta>a{background:#C49A2A !important;color:#08122A !important;font-weight:600;padding:8px 22px !important;border-radius:2px;letter-spacing:0.04em;line-height:normal}\n.bmiil-nav-menu>li:last-child>a:hover,.bmiil-nav-menu>li.nav-cta>a:hover{background:#E2BF68 !important;color:#08122A !important}\n.bmiil-nav-menu>li.menu-item-has-children>a::after{content:\" \u25be\";font-size:9px;opacity:0.45;margin-left:2px}\n.bmiil-nav-menu>li>.sub-menu,.bmiil-nav-menu>li>ul{visibility:hidden;opacity:0;pointer-events:none;position:absolute;top:100%;left:0;z-index:10000;min-width:220px;background:#0F1F45;border:1px solid rgba(196,154,42,0.25);border-top:2px solid #C49A2A;border-radius:0 4px 4px 4px;padding:6px 0;box-shadow:0 16px 48px rgba(0,0,0,0.7);list-style:none !important;margin:0;transition:opacity .15s ease,visibility .15s ease,transform .15s ease;transform:translateY(4px)}\n.bmiil-nav-menu>li>.sub-menu::before,.bmiil-nav-menu>li>ul::before{content:\"\";position:absolute;top:-12px;left:0;right:0;height:12px;background:transparent}\n.bmiil-nav-menu>li:hover>.sub-menu,.bmiil-nav-menu>li:hover>ul,.bmiil-nav-menu>li:focus-within>.sub-menu,.bmiil-nav-menu>li:focus-within>ul{visibility:visible;opacity:1;pointer-events:auto;transform:translateY(0)}\n.bmiil-nav-menu .sub-menu li,.bmiil-nav-menu>li>ul li{list-style:none !important;border-bottom:1px solid rgba(255,255,255,0.05)}\n.bmiil-nav-menu .sub-menu li:last-child,.bmiil-nav-menu>li>ul li:last-child{border-bottom:none}\n.bmiil-nav-menu .sub-menu li a,.bmiil-nav-menu>li>ul li a{font-family:DM Sans,sans-serif !important;font-size:13px !important;color:rgba(255,255,255,0.65) !important;background:transparent !important;padding:11px 20px !important;display:block;white-space:nowrap;letter-spacing:0.03em;font-weight:400 !important;line-height:normal;text-decoration:none !important;transition:background .12s,color .12s,padding-left .12s}\n.bmiil-nav-menu .sub-menu li a:hover,.bmiil-nav-menu>li>ul li a:hover{color:#E2BF68 !important;background:rgba(196,154,42,0.1) !important;padding-left:26px !important}\n@media(max-width:900px){\n  #bmiil-menu-container{display:none !important}\n  #bmiil-hamburger{display:flex !important}\n  .bmiil-nav-menu{flex-direction:column !important;gap:0 !important;align-items:flex-start !important}\n  .bmiil-nav-menu>li{width:100%}\n  .bmiil-nav-menu>li>a{padding:0.85rem 0 !important;font-size:15px !important;line-height:normal !important;color:rgba(255,255,255,0.75) !important;border-bottom:1px solid rgba(255,255,255,0.06)}\n  .bmiil-nav-menu>li>.sub-menu,.bmiil-nav-menu>li>ul{position:static !important;visibility:hidden;opacity:0;max-height:0;overflow:hidden;transform:none !important;box-shadow:none !important;border:none !important;border-left:2px solid rgba(196,154,42,0.3) !important;border-radius:0 !important;margin:0 0 0 1rem;background:rgba(255,255,255,0.03) !important;transition:opacity .2s,max-height .25s,visibility .2s;padding:0 !important}\n  .bmiil-nav-menu>li.open>.sub-menu,.bmiil-nav-menu>li.open>ul{visibility:visible !important;opacity:1 !important;max-height:400px !important;pointer-events:auto !important}\n  .bmiil-nav-menu>li:hover>.sub-menu,.bmiil-nav-menu>li:hover>ul{visibility:hidden;opacity:0;pointer-events:none}\n  .bmiil-nav-menu>li.open>.sub-menu,.bmiil-nav-menu>li.open>ul{visibility:visible !important;opacity:1 !important;pointer-events:auto !important}\n}\n</style>\n\n<script>\n(function(){\n  function injectMenu(){\n    var src=document.getElementById(\"bmiil-nav-data\");\n    if(!src)return;\n    var menu=src.querySelector(\"ul.bmiil-nav-menu\");\n    if(!menu)return;\n    var slot=document.getElementById(\"bmiil-desktop-menu-slot\");\n    if(slot)slot.appendChild(menu.cloneNode(true));\n    var ms=document.getElementById(\"bmiil-mobile-menu-slot\");\n    if(ms){ms.innerHTML=\"\";ms.appendChild(menu.cloneNode(true));}\n    var path=window.location.pathname;\n    document.querySelectorAll(\".bmiil-nav-menu a\").forEach(function(a){\n      var h=a.getAttribute(\"href\")||\"\";\n      if(h!==\"/\"&&h!==\"\"&&path.indexOf(h)===0)a.style.color=\"#C49A2A\";\n    });\n  }\n  window.bmiilToggleMenu=function(){\n    var m=document.getElementById(\"bmiil-mobile-menu\");\n    var open=m.style.display===\"block\";\n    m.style.display=open?\"none\":\"block\";\n    document.getElementById(\"bmiil-hamburger\").setAttribute(\"aria-expanded\",String(!open));\n  };\n  function initMobile(){\n    if(window.innerWidth>900)return;\n    document.querySelectorAll(\".bmiil-nav-menu>li.menu-item-has-children>a\").forEach(function(a){\n      a.addEventListener(\"click\",function(e){\n        var li=this.closest(\"li\"),isOpen=li.classList.contains(\"open\");\n        document.querySelectorAll(\".bmiil-nav-menu>li\").forEach(function(el){el.classList.remove(\"open\");});\n        if(!isOpen){e.preventDefault();li.classList.add(\"open\");}\n      });\n    });\n  }\n  document.addEventListener(\"click\",function(e){\n    if(!e.target.closest(\".bmiil-nav-menu\"))\n      document.querySelectorAll(\".bmiil-nav-menu>li\").forEach(function(el){el.classList.remove(\"open\");});\n  });\n  window.addEventListener(\"scroll\",function(){\n    var n=document.getElementById(\"bmiil-nav\");\n    if(n)n.style.background=window.scrollY>60?\"rgba(8,18,42,0.99)\":\"#08122A\";\n  },{passive:true});\n  if(document.readyState===\"loading\"){\n    document.addEventListener(\"DOMContentLoaded\",function(){injectMenu();initMobile();});\n  }else{injectMenu();initMobile();}\n})();\n</script>\n\n</div>"
