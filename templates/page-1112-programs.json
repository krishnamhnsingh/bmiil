              "settings": {
                "html": "<div style=\"background:#08122A;padding:3.75rem 3.75rem 7rem;border-bottom:1px solid rgba(196,154,42,0.15);position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;\"></div>\n  <div style=\"max-width:1220px;margin:0 auto;padding:0;position:relative;z-index:1;\">\n    \n    <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:1.8rem;\"><div style=\"width:40px;height:1px;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;\">Our Programs</span></div>\n    <h1 style=\"font-family:Cormorant Garamond;font-size:clamp(2.8rem,5vw,5rem);font-weight:300;line-height:1.04;color:#FFFFFF;margin:0 0 1.8rem;\">Three Programs.<br>One Mission.</h1>\n    <p style=\"font-size:1rem;line-height:1.7;color:rgba(255,255,255,0.5);max-width:600px;margin:1.5rem 0 0;\">Whether you're a clinician with an idea, an engineer solving a real problem, or a startup ready to scale \u2014 BMIIL has a structured program built for exactly where you are right now.</p>\n  </div>\n</div>"
