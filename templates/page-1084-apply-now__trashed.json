              "elType": "widget",
              "settings": {
                "html": "\n<div style=\"background:#08122A;padding:160px 0 64px;border-bottom:1px solid rgba(196,154,42,0.15);position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;\"></div>\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;position:relative;z-index:1;\">\n    <div style=\"font-family:DM Mono;font-size:10px;color:rgba(255,255,255,0.3);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:3rem;\"><a href=\"/\" style=\"color:rgba(255,255,255,0.3);text-decoration:none;\">Home</a> <span style=\"opacity:.4;\">/</span> <span style=\"color:{GOLD};\">Apply Now</span></div>\n    <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:1.8rem;\"><div style=\"width:40px;height:1px;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;\">Cohort 1 \u2014 Applications Open</span></div>\n    <h1 style=\"font-family:Cormorant Garamond;font-size:clamp(2.5rem,5vw,5rem);font-weight:300;line-height:1.04;color:#FFFFFF;margin:0 0 1.8rem;\">This is where your idea<br>becomes <em style='font-style:italic;color:{GOLD_LT};'>a company.</em></h1>\n    <p style=\"font-size:1rem;line-height:1.7;color:rgba(255,255,255,0.5);max-width:600px;margin:1.5rem 0 0;\">10\u201312 seats across three tracks. One cohort. Applications reviewed on a rolling basis \u2014 the sooner you apply, the better your chance.</p>\n  </div>\n</div>\n\n<div style=\"background:#F7F3EC;padding:7rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;display:grid;grid-template-columns:1fr 1.2fr;gap:5rem;align-items:start;\">\n\n    <!-- Track selector -->\n    <div>\n      <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">Choose Your Track</p>\n      <h2 style=\"font-family:Cormorant Garamond;font-size:2rem;font-weight:300;color:#08122A;margin:0 0 1.5rem;\">Which program are you applying for?</h2>\n      <div style=\"display:flex;flex-direction:column;gap:1rem;\">\n        <div style=\"background:#08122A;border:1px solid rgba(196,154,42,0.4);border-radius:4px;padding:1.5rem 1.8rem;cursor:pointer;position:relative;overflow:hidden;\"><div style=\"position:absolute;top:0;left:0;right:0;height:2px;background:#C49A2A;\"></div><div style=\"font-family:Cormorant Garamond;font-size:1.1rem;font-weight:700;color:#FFFFFF;margin-bottom:0.3rem;\">Medtech Incubation</div><div style=\"font-size:12px;color:rgba(255,255,255,0.5);\">Idea \u2192 Validated Product \u00b7 12 months</div></div>\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.5rem 1.8rem;cursor:pointer;position:relative;overflow:hidden;\"><div style=\"font-family:Cormorant Garamond;font-size:1.1rem;font-weight:700;color:#08122A;margin-bottom:0.3rem;\">Accelerator</div><div style=\"font-size:12px;color:#7A8BA8;\">Traction \u2192 Scale \u00b7 6 months</div></div>\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.5rem 1.8rem;cursor:pointer;position:relative;overflow:hidden;\"><div style=\"font-family:Cormorant Garamond;font-size:1.1rem;font-weight:700;color:#08122A;margin-bottom:0.3rem;\">Ayush Incubation</div><div style=\"font-size:12px;color:#7A8BA8;\">Traditional Medicine \u2192 Market \u00b7 12 months</div></div>\n      </div>\n      <div style=\"margin-top:3rem;padding:2rem;background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;\">\n        <h4 style=\"font-family:Cormorant Garamond;font-size:1rem;font-weight:700;color:#08122A;margin:0 0 0.5rem;\">Not sure which track?</h4>\n        <p style=\"font-size:13px;color:#7A8BA8;margin:0 0 1rem;\">Read the program pages carefully \u2014 or just tell us your stage in the form and we'll suggest the right fit.</p>\n        <a href=\"/programs/\" style=\"font-size:13px;color:#C49A2A;text-decoration:none;font-weight:500;\">Compare All Programs \u2192</a>\n      </div>\n    </div>\n\n    <!-- Process steps -->\n    <div>\n      <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">What to Expect</p>\n      <h2 style=\"font-family:Cormorant Garamond;font-size:2rem;font-weight:300;color:#08122A;margin:0 0 1.5rem;\">Before you apply.</h2>\n      <div style=\"display:flex;flex-direction:column;gap:1rem;margin-bottom:3rem;\">\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.8rem;display:flex;gap:1.2rem;align-items:flex-start;\">\n  <div style=\"font-size:1.4rem;flex-shrink:0;\">\u23f1\ufe0f</div>\n  <div><h4 style=\"font-family:Cormorant Garamond;font-size:1.05rem;font-weight:700;color:#08122A;margin:0 0 0.4rem;\">Takes 15\u201320 Minutes</h4><p style=\"font-size:13px;line-height:1.6;color:#7A8BA8;margin:0;\">Three short sections. No deck required at this stage \u2014 just clear answers about you, your idea, and your track preference.</p></div>\n</div>\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.8rem;display:flex;gap:1.2rem;align-items:flex-start;\">\n  <div style=\"font-size:1.4rem;flex-shrink:0;\">\ud83d\udd01</div>\n  <div><h4 style=\"font-family:Cormorant Garamond;font-size:1.05rem;font-weight:700;color:#08122A;margin:0 0 0.4rem;\">Rolling Review</h4><p style=\"font-size:13px;line-height:1.6;color:#7A8BA8;margin:0;\">We review applications as they come in. Early applicants get more time with the team. Don't wait until the deadline.</p></div>\n</div>\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.8rem;display:flex;gap:1.2rem;align-items:flex-start;\">\n  <div style=\"font-size:1.4rem;flex-shrink:0;\">\ud83d\udcde</div>\n  <div><h4 style=\"font-family:Cormorant Garamond;font-size:1.05rem;font-weight:700;color:#08122A;margin:0 0 0.4rem;\">Interview Within 2 Weeks</h4><p style=\"font-size:13px;line-height:1.6;color:#7A8BA8;margin:0;\">Shortlisted applicants are invited for a 30-minute video call \u2014 no presentations, just a conversation.</p></div>\n</div>\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.8rem;display:flex;gap:1.2rem;align-items:flex-start;\">\n  <div style=\"font-size:1.4rem;flex-shrink:0;\">\ud83d\udcc4</div>\n  <div><h4 style=\"font-family:Cormorant Garamond;font-size:1.05rem;font-weight:700;color:#08122A;margin:0 0 0.4rem;\">Offer Within 5 Days</h4><p style=\"font-size:13px;line-height:1.6;color:#7A8BA8;margin:0;\">If selected, you'll receive a formal offer letter with all program terms within 5 business days. No ambiguity.</p></div>\n</div>\n        <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.8rem;display:flex;gap:1.2rem;align-items:flex-start;\">\n  <div style=\"font-size:1.4rem;flex-shrink:0;\">\ud83d\udd12</div>\n  <div><h4 style=\"font-family:Cormorant Garamond;font-size:1.05rem;font-weight:700;color:#08122A;margin:0 0 0.4rem;\">Your Idea is Safe</h4><p style=\"font-size:13px;line-height:1.6;color:#7A8BA8;margin:0;\">All applications are treated as confidential. We do not share your information with third parties.</p></div>\n</div>\n      </div>\n      <a href=\"/apply/form/\" style=\"background:#C49A2A;color:#08122A;font-weight:600;font-size:14px;letter-spacing:1px;padding:14px 32px;border-radius:2px;text-decoration:none;display:inline-block;\">Start Your Application \u2192</a>\n    </div>\n\n  </div>\n</div>\n\n<!-- Timeline -->\n<div style=\"background:#08122A;padding:5rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;\">\n    <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.1);margin:0 0 20px 0;\">What Happens After You Submit</p>\n    <div style=\"display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:2rem;\">\n      <div style=\"text-align:center;padding:1.5rem;position:relative;\"><div style=\"width:40px;height:40px;border-radius:50%;background:rgba(196,154,42,0.15);border:1px solid rgba(196,154,42,0.3);display:flex;align-items:center;justify-content:center;font-family:DM Mono;font-size:11px;font-weight:700;color:#C49A2A;margin:0 auto 1rem;position:relative;z-index:1;\">1</div><div style=\"font-size:12px;font-weight:600;color:#FFFFFF;margin-bottom:0.3rem;\">Application received</div><div style=\"font-size:11px;color:rgba(255,255,255,0.4);\">Immediate</div></div><div style=\"text-align:center;padding:1.5rem;position:relative;\"><div style=\"position:absolute;top:2rem;left:0;width:50%;height:1px;background:rgba(196,154,42,0.3);\"></div><div style=\"width:40px;height:40px;border-radius:50%;background:rgba(196,154,42,0.15);border:1px solid rgba(196,154,42,0.3);display:flex;align-items:center;justify-content:center;font-family:DM Mono;font-size:11px;font-weight:700;color:#C49A2A;margin:0 auto 1rem;position:relative;z-index:1;\">2</div><div style=\"font-size:12px;font-weight:600;color:#FFFFFF;margin-bottom:0.3rem;\">Initial screening</div><div style=\"font-size:11px;color:rgba(255,255,255,0.4);\">Within 7 days</div></div><div style=\"text-align:center;padding:1.5rem;position:relative;\"><div style=\"position:absolute;top:2rem;left:0;width:50%;height:1px;background:rgba(196,154,42,0.3);\"></div><div style=\"width:40px;height:40px;border-radius:50%;background:rgba(196,154,42,0.15);border:1px solid rgba(196,154,42,0.3);display:flex;align-items:center;justify-content:center;font-family:DM Mono;font-size:11px;font-weight:700;color:#C49A2A;margin:0 auto 1rem;position:relative;z-index:1;\">3</div><div style=\"font-size:12px;font-weight:600;color:#FFFFFF;margin-bottom:0.3rem;\">Shortlist notification</div><div style=\"font-size:11px;color:rgba(255,255,255,0.4);\">Day 7\u201310</div></div><div style=\"text-align:center;padding:1.5rem;position:relative;\"><div style=\"position:absolute;top:2rem;left:0;width:50%;height:1px;background:rgba(196,154,42,0.3);\"></div><div style=\"width:40px;height:40px;border-radius:50%;background:rgba(196,154,42,0.15);border:1px solid rgba(196,154,42,0.3);display:flex;align-items:center;justify-content:center;font-family:DM Mono;font-size:11px;font-weight:700;color:#C49A2A;margin:0 auto 1rem;position:relative;z-index:1;\">4</div><div style=\"font-size:12px;font-weight:600;color:#FFFFFF;margin-bottom:0.3rem;\">Video interview</div><div style=\"font-size:11px;color:rgba(255,255,255,0.4);\">Week 2\u20133</div></div><div style=\"text-align:center;padding:1.5rem;position:relative;\"><div style=\"position:absolute;top:2rem;left:0;width:50%;height:1px;background:rgba(196,154,42,0.3);\"></div><div style=\"width:40px;height:40px;border-radius:50%;background:rgba(196,154,42,0.15);border:1px solid rgba(196,154,42,0.3);display:flex;align-items:center;justify-content:center;font-family:DM Mono;font-size:11px;font-weight:700;color:#C49A2A;margin:0 auto 1rem;position:relative;z-index:1;\">5</div><div style=\"font-size:12px;font-weight:600;color:#FFFFFF;margin-bottom:0.3rem;\">Offer letter</div><div style=\"font-size:11px;color:rgba(255,255,255,0.4);\">5 days post-interview</div></div>\n    </div>\n  </div>\n</div>"
              },
