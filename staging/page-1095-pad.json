            "elType": "widget",
            "settings": {
              "html": "\n<div style=\"background:#08122A;padding:2.5rem 2.5rem 7rem;border-bottom:1px solid rgba(196,154,42,0.15);position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;\"></div>\n  <div style=\"max-width:1220px;margin:0 auto;padding:2.5rem 2.5rem 7rem;position:relative;z-index:1;\">\n    \n    <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:1.8rem;\"><div style=\"width:40px;height:1px;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C49A2A;\">Get in Touch</span></div>\n    <h1 style=\"font-family:Cormorant Garamond;font-size:clamp(2.5rem,5vw,5rem);font-weight:300;line-height:1.04;color:#FFFFFF;margin:0 0 1.8rem;\">Every great startup<br>begins with a conversation.</h1>\n    <p style=\"font-size:1rem;line-height:1.7;color:rgba(255,255,255,0.5);max-width:600px;margin:1.5rem 0 0;\">We're a small team and we read every message ourselves. Tell us who you are and what you're working on \u2014 we'll take it from there.</p>\n  </div>\n</div>\n\n<div style=\"background:#F7F3EC;padding:7rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:2.5rem 2.5rem 7rem;display:grid;grid-template-columns:1fr 1fr;gap:5rem;\">\n\n    <!-- Left: Enquiry types + details -->\n    <div>\n      <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">Enquiry Type</p>\n      <h3 style=\"font-family:Cormorant Garamond;font-size:1.5rem;font-weight:300;color:#08122A;margin:0 0 1.5rem;\">I'm reaching out as a\u2026</h3>\n      <div style=\"display:flex;flex-direction:column;gap:0.8rem;margin-bottom:3rem;\">\n        <div style=\"display:flex;gap:1.2rem;padding:1.2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;cursor:pointer;align-items:flex-start;\">\n  <span style=\"font-size:1.3rem;flex-shrink:0;\">\ud83d\udca1</span>\n  <div><div style=\"font-family:Cormorant Garamond;font-size:1rem;font-weight:700;color:#08122A;margin-bottom:2px;\">General Enquiry</div><div style=\"font-size:12px;color:#7A8BA8;\">Any question at all</div></div>\n</div>\n        <div style=\"display:flex;gap:1.2rem;padding:1.2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;cursor:pointer;align-items:flex-start;\">\n  <span style=\"font-size:1.3rem;flex-shrink:0;\">\ud83d\ude80</span>\n  <div><div style=\"font-family:Cormorant Garamond;font-size:1rem;font-weight:700;color:#08122A;margin-bottom:2px;\">I'm a Founder</div><div style=\"font-size:12px;color:#7A8BA8;\">Program or application questions</div></div>\n</div>\n        <div style=\"display:flex;gap:1.2rem;padding:1.2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;cursor:pointer;align-items:flex-start;\">\n  <span style=\"font-size:1.3rem;flex-shrink:0;\">\ud83d\udcbc</span>\n  <div><div style=\"font-family:Cormorant Garamond;font-size:1rem;font-weight:700;color:#08122A;margin-bottom:2px;\">I'm an Investor</div><div style=\"font-size:12px;color:#7A8BA8;\">Partnership or portfolio interest</div></div>\n</div>\n        <div style=\"display:flex;gap:1.2rem;padding:1.2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;cursor:pointer;align-items:flex-start;\">\n  <span style=\"font-size:1.3rem;flex-shrink:0;\">\ud83c\udfe5</span>\n  <div><div style=\"font-family:Cormorant Garamond;font-size:1rem;font-weight:700;color:#08122A;margin-bottom:2px;\">Corporate / Hospital Partner</div><div style=\"font-size:12px;color:#7A8BA8;\">Strategic partnership enquiry</div></div>\n</div>\n        <div style=\"display:flex;gap:1.2rem;padding:1.2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;cursor:pointer;align-items:flex-start;\">\n  <span style=\"font-size:1.3rem;flex-shrink:0;\">\ud83d\udcf0</span>\n  <div><div style=\"font-family:Cormorant Garamond;font-size:1rem;font-weight:700;color:#08122A;margin-bottom:2px;\">Press / Media</div><div style=\"font-size:12px;color:#7A8BA8;\">Coverage or interview request</div></div>\n</div>\n      </div>\n\n      <div style=\"background:#08122A;border-radius:4px;padding:2.5rem;\">\n        <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.1);margin:0 0 20px 0;\">Contact Details</p>\n        <div style=\"display:flex;flex-direction:column;gap:1.2rem;\">\n          <div style=\"display:flex;gap:1.2rem;align-items:flex-start;\"><div style=\"width:42px;height:42px;min-width:42px;border-radius:3px;background:rgba(196,154,42,0.08);border:1px solid rgba(196,154,42,0.25);display:flex;align-items:center;justify-content:center;font-size:1.1rem;\">\u2709\ufe0f</div><div><h4 style=\"font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);margin:0 0 0.3rem;\">General Enquiries</h4><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\"><a href=\"mailto:info@bmiil.com\" style=\"color:{GOLD};text-decoration:none;\">info@bmiil.com</a></p><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\">Response within 24\u201348 hours</p></div></div>\n          <div style=\"display:flex;gap:1.2rem;align-items:flex-start;\"><div style=\"width:42px;height:42px;min-width:42px;border-radius:3px;background:rgba(196,154,42,0.08);border:1px solid rgba(196,154,42,0.25);display:flex;align-items:center;justify-content:center;font-size:1.1rem;\">\ud83d\udccb</div><div><h4 style=\"font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);margin:0 0 0.3rem;\">Program Applications</h4><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\"><a href=\"/apply/\" style=\"color:{GOLD};text-decoration:none;\">Apply via online form \u2192</a></p><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\">Or email: apply@bmiil.com</p></div></div>\n          <div style=\"display:flex;gap:1.2rem;align-items:flex-start;\"><div style=\"width:42px;height:42px;min-width:42px;border-radius:3px;background:rgba(196,154,42,0.08);border:1px solid rgba(196,154,42,0.25);display:flex;align-items:center;justify-content:center;font-size:1.1rem;\">\ud83d\udcbc</div><div><h4 style=\"font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);margin:0 0 0.3rem;\">Investor & Partner Relations</h4><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\"><a href=\"mailto:partners@bmiil.com\" style=\"color:{GOLD};text-decoration:none;\">partners@bmiil.com</a></p><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\">Response within 24 hours</p></div></div>\n          <div style=\"display:flex;gap:1.2rem;align-items:flex-start;\"><div style=\"width:42px;height:42px;min-width:42px;border-radius:3px;background:rgba(196,154,42,0.08);border:1px solid rgba(196,154,42,0.25);display:flex;align-items:center;justify-content:center;font-size:1.1rem;\">\ud83d\udccd</div><div><h4 style=\"font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);margin:0 0 0.3rem;\">Campus Address</h4><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\">Bareilly International University</p><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\">Pilibhit Bypass Road, Bareilly \u2014 243006</p><p style=\"font-size:12px;color:rgba(255,255,255,0.35);margin:0;line-height:1.6;\">Uttar Pradesh, India</p></div></div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Right: Form -->\n    <div>\n      <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">Send Us a Message</p>\n      <h3 style=\"font-family:Cormorant Garamond;font-size:1.5rem;font-weight:300;color:#08122A;margin:0 0 0.5rem;\">We read every message.</h3>\n      <p style=\"font-size:14px;color:#7A8BA8;margin:0 0 2rem;\">Tell us who you are and what's on your mind.</p>\n\n      <form method=\"POST\" action=\"https://formsubmit.co/info@bmiil.com\" style=\"display:flex;flex-direction:column;gap:1rem;\">\n        <input type=\"hidden\" name=\"_subject\" value=\"New Message from BMIIL Contact Form\">\n        <input type=\"hidden\" name=\"_next\" value=\"https://test.bmiil.com/contact/?sent=true\">\n        <input type=\"hidden\" name=\"_captcha\" value=\"false\">\n        <input type=\"hidden\" name=\"_template\" value=\"table\">\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1rem;\">\n          <div><label style=\"font-size:12px;font-weight:600;color:#1B2A4A;display:block;margin-bottom:6px;\">First Name *</label><input type=\"text\" name=\"first_name\" required placeholder=\"First name\" style=\"width:100%;padding:10px 14px;border:1px solid #EDE8DE;border-radius:3px;font-size:14px;background:#FFFFFF;box-sizing:border-box;\"></div>\n          <div><label style=\"font-size:12px;font-weight:600;color:#1B2A4A;display:block;margin-bottom:6px;\">Last Name *</label><input type=\"text\" name=\"last_name\" required placeholder=\"Last name\" style=\"width:100%;padding:10px 14px;border:1px solid #EDE8DE;border-radius:3px;font-size:14px;background:#FFFFFF;box-sizing:border-box;\"></div>\n        </div>\n        <div><label style=\"font-size:12px;font-weight:600;color:#1B2A4A;display:block;margin-bottom:6px;\">Email Address *</label><input type=\"email\" name=\"email\" required placeholder=\"your@email.com\" style=\"width:100%;padding:10px 14px;border:1px solid #EDE8DE;border-radius:3px;font-size:14px;background:#FFFFFF;box-sizing:border-box;\"></div>\n        <div><label style=\"font-size:12px;font-weight:600;color:#1B2A4A;display:block;margin-bottom:6px;\">Organisation</label><input type=\"text\" name=\"organisation\" placeholder=\"Company or institution (optional)\" style=\"width:100%;padding:10px 14px;border:1px solid #EDE8DE;border-radius:3px;font-size:14px;background:#FFFFFF;box-sizing:border-box;\"></div>\n        <div><label style=\"font-size:12px;font-weight:600;color:#1B2A4A;display:block;margin-bottom:6px;\">I'm reaching out as a\u2026 *</label><select name=\"role\" required style=\"width:100%;padding:10px 14px;border:1px solid #EDE8DE;border-radius:3px;font-size:14px;background:#FFFFFF;box-sizing:border-box;\"><option value=\"\">Select your role</option><option>Founder / Entrepreneur</option><option>Researcher / Academic</option><option>Investor / Fund Manager</option><option>Corporate / Hospital Partner</option><option>Student</option><option>Press / Media</option><option>Other</option></select></div>\n        <div><label style=\"font-size:12px;font-weight:600;color:#1B2A4A;display:block;margin-bottom:6px;\">Your Message *</label><textarea name=\"message\" required placeholder=\"Tell us what's on your mind\u2026\" rows=\"5\" style=\"width:100%;padding:10px 14px;border:1px solid #EDE8DE;border-radius:3px;font-size:14px;background:#FFFFFF;resize:vertical;box-sizing:border-box;font-family:DM Sans;\"></textarea></div>\n        <button type=\"submit\" style=\"background:#C49A2A;color:#08122A;font-weight:600;font-size:14px;letter-spacing:1px;padding:14px 32px;border:none;border-radius:2px;cursor:pointer;text-align:left;\">Send Message \u2192</button>\n        <p style=\"font-size:11px;color:#7A8BA8;margin:0;\">\ud83d\udd12 Your message is sent directly to info@bmiil.com</p>\n      </form>\n    </div>\n  </div>\n</div>\n<div id=\"bmiil-contact-success\" style=\"display:none;background:#0F1F45;border:1px solid rgba(196,154,42,0.3);border-radius:4px;padding:1.5rem 2rem;margin-top:1rem;text-align:center;\"><p style=\"font-family:Cormorant Garamond;font-size:1.3rem;font-weight:700;color:#FFFFFF;margin:0 0 0.3rem;\">\u2713 Message Sent!</p><p style=\"font-size:13px;color:rgba(255,255,255,0.6);margin:0;\">Thank you. We'll get back to you at your email address shortly.</p></div><script>if(window.location.search.includes(\"sent=true\")){var el=document.getElementById(\"bmiil-contact-success\");if(el){el.style.display=\"block\";el.scrollIntoView({behavior:\"smooth\"});}}</script>"
            },
