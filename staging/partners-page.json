-radius:4px;padding:2.5rem;\"><input type=\"hidden\" name=\"_subject\" value=\"New Partnership / Investor Enquiry \u2014 BMIIL\"><input type=\"hidden\" name=\"_next\" value=\"https://test.bmiil.com/investor-deck/?sent=true\"><input type=\"hidden\" name=\"_captcha\" value=\"false\"><input type=\"hidden\" name=\"_template\" value=\"table\"><h3 style=\"font-family:Cormorant Garamond;font-size:1.4rem;font-weight:700;color:#08122A;margin:0 0 0.3rem;\">Partnership Enquiry Form</h3><p style=\"font-size:13px;color:#7A8BA8;margin:0 0 0.5rem;\">All fields marked <span style=\"color:#C49A2A;\">*</span> are required.</p><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1rem;\"><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Full Name <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"full_name\" required placeholder=\"Your full name\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Organisation / Company <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"organisation\" required placeholder=\"Company or institution\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Designation / Role <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"designation\" required placeholder=\"e.g. CEO, Investment Director\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Email Address <span style=\"color:#C49A2A;\">*</span></label><input type=\"email\" name=\"email\" required placeholder=\"your@email.com\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Phone Number <span style=\"color:#C49A2A;\">*</span></label><input type=\"tel\" name=\"phone\" required placeholder=\"+91 00000 00000\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Website / LinkedIn</label><input type=\"text\" name=\"website\"  placeholder=\"https://\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">I am interested in collaborating as a <span style=\"color:#C49A2A;\">*</span></label><select name=\"collaboration_type\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\"><option value=\"\">-- Select --</option><option value=\"Investor\">Investor</option><option value=\"Corporate Partner\">Corporate Partner</option><option value=\"CSR Collaborator\">CSR Collaborator</option><option value=\"Mentor / Expert\">Mentor / Expert</option><option value=\"Research Partner\">Research Partner</option><option value=\"Hospital / Clinical Partner\">Hospital / Clinical Partner</option><option value=\"International Partner\">International Partner</option><option value=\"Other\">Other</option></select></div><div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">What kind of collaboration are you interested in? <span style=\"color:#C49A2A;\">*</span></label><textarea name=\"collaboration_details\" required rows=\"4\" placeholder=\"Describe what you have in mind...\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;resize:vertical;outline:none;\"></textarea></div><button type=\"submit\" style=\"background:#C49A2A;color:#08122A;font-weight:700;font-size:14px;letter-spacing:0.06em;padding:16px 40px;border-radius:2px;border:none;cursor:pointer;font-family:DM Sans;text-transform:uppercase;width:100%;\">Join the Movement \u2192</button><p style=\"font-size:11px;color:#7A8BA8;text-align:center;margin:0;\">Sent directly to <strong>info@bmiil.com</strong> \u00b7 We respond within 48 hours</p></form></div></div></div>"
