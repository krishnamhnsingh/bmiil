            "settings": {
              "html": "<div style=\"background:#F7F3EC;padding:7rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;\">\n    <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">Leadership</p>\n    <h2 style=\"font-family:Cormorant Garamond;font-size:clamp(2.2rem,4vw,3.5rem);font-weight:300;line-height:1.15;color:#08122A;margin:0 0 0.8rem;\"><strong style=\"font-weight:700;\">The team</strong><br>behind the mission</h2>\n    <p style=\"font-size:15px;line-height:1.8;color:#4A5C78;max-width:540px;margin:0 0 3.5rem;\">Led by practitioners, researchers, and institution builders \u2014 people who have spent careers in healthcare, not just business.</p>\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;\">\n      <div style=\"text-align:center;padding:2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;transition:box-shadow .3s,transform .3s;\">\n  <div style=\"width:90px;height:90px;border-radius:50%;border:2px solid rgba(196,154,42,0.25);margin:0 auto 1.2rem;overflow:hidden;background:#0F1F45;\">\n    <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/Dr.-Varun-Agarwal.webp\" alt=\"Dr. Varun Agarwal\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n  </div>\n  <div style=\"font-family:Cormorant Garamond;font-size:1.1rem;font-weight:700;color:#08122A;margin-bottom:0.3rem;\">Dr. Varun Agarwal</div>\n  <div style=\"font-size:12px;color:#7A8BA8;margin-bottom:0.5rem;line-height:1.4;\">Founder &amp; Advisory Board Member</div>\n  <div style=\"font-family:DM Mono;font-size:10px;color:#C49A2A;letter-spacing:0.1em;\">MBBS \u00b7 MD Orthopaedics &amp; Spine Surgery</div>\n</div><div style=\"text-align:center;padding:2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;transition:box-shadow .3s,transform .3s;\">\n  <div style=\"width:90px;height:90px;border-radius:50%;border:2px solid rgba(196,154,42,0.25);margin:0 auto 1.2rem;overflow:hidden;background:#0F1F45;\">\n    <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/drarjunagarwal.webp\" alt=\"Dr. Arjun Agarwal\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n  </div>\n  <div style=\"font-family:Cormorant Garamond;font-size:1.1rem;font-weight:700;color:#08122A;margin-bottom:0.3rem;\">Dr. Arjun Agarwal</div>\n  <div style=\"font-size:12px;color:#7A8BA8;margin-bottom:0.5rem;line-height:1.4;\">Co-founder &amp; Advisory Board Member</div>\n  <div style=\"font-family:DM Mono;font-size:10px;color:#C49A2A;letter-spacing:0.1em;\">MBBS, MS, MCh Surgical Oncology \u00b7 Rohilkhand Cancer Institute</div>\n</div><div style=\"text-align:center;padding:2rem 1.5rem;border:1px solid #EDE8DE;border-radius:4px;background:#FFFFFF;transition:box-shadow .3s,transform .3s;\">\n  <div style=\"width:90px;height:90px;border-radius:50%;border:2px solid rgba(196,154,42,0.25);margin:0 auto 1.2rem;overflow:hidden;background:#0F1F45;\">\n    <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/claudius-e1761136422449.webp\" alt=\"Claudius Lazarus\" style=\"width:100%;height:100%;object-fit:cover;display:block;\">\n  </div>\n  <div style=\"font-family:Cormorant Garamond;font-size:1.1rem;font-weight:700;color:#08122A;margin-bottom:0.3rem;\">Claudius Lazarus</div>\n  <div style=\"font-size:12px;color:#7A8BA8;margin-bottom:0.5rem;line-height:1.4;\">Co-founder &amp; CEO</div>\n  <div style=\"font-family:DM Mono;font-size:10px;color:#C49A2A;letter-spacing:0.1em;\">Technology Entrepreneur \u00b7 25+ Years</div>\n</div>\n    </div>\n    <div style=\"text-align:center;margin-top:2.5rem;\">\n      <a href=\"/team/\" style=\"background:transparent;color:#08122A;font-weight:500;font-size:13px;padding:12px 28px;border:1px solid rgba(0,0,0,0.15);border-radius:2px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;\">Meet the Full Team \u2192</a>\n    </div>\n  </div>\n</div>"
