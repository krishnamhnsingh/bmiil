            "id": "f6a30ae",
            "elType": "widget",
            "settings": {
              "html": "<div style=\"background:#08122A;padding:5rem 0;overflow:hidden;position:relative;\">\n  <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(196,154,42,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(196,154,42,0.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;\"></div>\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;display:flex;align-items:center;gap:5rem;position:relative;z-index:1;\">\n    <div style=\"flex-shrink:0;width:120px;height:120px;border-radius:50%;border:2px solid #C49A2A;display:flex;align-items:center;justify-content:center;background:rgba(196,154,42,0.08);color:#C49A2A;\"><img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/logo-small.webp\" alt=\"BIU Logo\" style=\"width:116px;height:116px;object-fit:contain;display:block;border-radius:50%;\"></div>\n    <div style=\"flex:1;\">\n      <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.1);margin:0 0 20px 0;\">Hosted By</p>\n      <h2 style=\"font-family:Cormorant Garamond;font-size:clamp(1.6rem,3vw,2.5rem);font-weight:300;color:#FFFFFF;margin:0 0 1rem;\">Proudly hosted by<br><strong style=\"font-weight:700;color:#E2BF68;\">Bareilly International University</strong></h2>\n      <p style=\"font-size:14px;line-height:1.8;color:rgba(255,255,255,0.5);max-width:600px;margin:0 0 1.5rem;\">One of North India's premier private universities, BIU provides BMIIL's startups with direct access to clinical environments, advanced research infrastructure, and a multidisciplinary faculty across Medicine, Ayurveda, Pharmacy, Nursing, Dental Sciences, and Allied Health.</p>\n      <div style=\"display:flex;gap:2rem;flex-wrap:wrap;\"><div style=\"display:flex;align-items:center;gap:8px;\"><div style=\"width:6px;height:6px;border-radius:50%;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-size:13px;color:rgba(255,255,255,0.65);\">Multi-speciality Teaching Hospital</span></div><div style=\"display:flex;align-items:center;gap:8px;\"><div style=\"width:6px;height:6px;border-radius:50%;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-size:13px;color:rgba(255,255,255,0.65);\">NAAC Accredited Colleges</span></div><div style=\"display:flex;align-items:center;gap:8px;\"><div style=\"width:6px;height:6px;border-radius:50%;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-size:13px;color:rgba(255,255,255,0.65);\">Industry Research Partnerships</span></div><div style=\"display:flex;align-items:center;gap:8px;\"><div style=\"width:6px;height:6px;border-radius:50%;background:#C49A2A;flex-shrink:0;\"></div><span style=\"font-size:13px;color:rgba(255,255,255,0.65);\">Pilibhit Bypass Campus, Bareilly</span></div></div>\n    </div>\n  </div>\n</div>"
            },
