            "id": "4ab7a34",
            "elType": "widget",
            "settings": {
              "html": "<style>\n@media(max-width:768px){\n  .bmiil-programs-grid{grid-template-columns:1fr!important;}\n  .bmiil-programs-grid>div{min-height:auto!important;}\n  .bmiil-hero-h1{font-size:2.4rem!important;}\n  .bmiil-stats-bar{flex-direction:column!important;gap:1rem!important;}\n  .bmiil-stats-bar>div{border:none!important;padding:0.5rem 1rem!important;}\n}\n</style>\n<div id=\"programs\" style=\"background:#F7F3EC;padding:7rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;\">\n    <div style=\"display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3.5rem;flex-wrap:wrap;gap:1rem;\">\n      <div><p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 20px 0;\">Programs</p><h2 style=\"font-family:Cormorant Garamond;font-size:clamp(2.2rem,4vw,3.5rem);font-weight:300;line-height:1.15;color:#08122A;margin:0;\"><strong style=\"font-weight:700;\">Three pathways.</strong><br><em style=\"font-style:italic;color:#C49A2A;\">One destination.</em></h2></div>\n      <a href=\"/programs/\" style=\"font-size:13px;color:#C49A2A;text-decoration:none;font-weight:500;white-space:nowrap;\">View All Programs \u2192</a>\n    </div>\n    <div class=\"bmiil-programs-grid\" style=\"display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:1.5rem;align-items:stretch;\">\n      <div style=\"background:#08122A;border:1px solid rgba(196,154,42,0.3);border-radius:4px;padding:2.5rem 2rem;display:flex;flex-direction:column;position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;top:0;left:0;right:0;height:3px;background:#C49A2A;\"></div>\n  <span style=\"display:inline-block;font-family:DM Mono;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;background:rgba(196,154,42,0.1);border:1px solid rgba(196,154,42,0.3);padding:3px 10px;border-radius:2px;margin-bottom:1.2rem;\">Our Core Track</span>\n  <h3 style=\"font-family:Cormorant Garamond;font-size:1.7rem;font-weight:700;color:#FFFFFF;margin:0 0 0.8rem;line-height:1.15;\">Medtech Incubation</h3>\n  <p style=\"font-size:13px;line-height:1.7;color:rgba(255,255,255,0.5);margin:0 0 1.5rem;flex:1;\">For healthcare, biotech & medical device startups ready to build, validate, and scale. Deep technical support from ideation to clinical validation.</p>\n  <ul style=\"list-style:none;padding:0;margin:0 0 2rem;\"><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if True else rgba(0,0,0,0.05);color:rgba(255,255,255,0.7);\">\u2022 Medical devices & diagnostics</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if True else rgba(0,0,0,0.05);color:rgba(255,255,255,0.7);\">\u2022 Digital health & HealthTech</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if True else rgba(0,0,0,0.05);color:rgba(255,255,255,0.7);\">\u2022 Biotech & life sciences</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if True else rgba(0,0,0,0.05);color:rgba(255,255,255,0.7);\">\u2022 Lab access & prototyping</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if True else rgba(0,0,0,0.05);color:rgba(255,255,255,0.7);\">\u2022 CDSCO & FDA pathway guidance</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if True else rgba(0,0,0,0.05);color:rgba(255,255,255,0.7);\">\u2022 Investor & hospital network</li></ul>\n  <a href=\"/programs/medtech-incubation/\" style=\"font-size:13px;font-weight:600;color:#C49A2A;text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-top:auto;\">Explore Track \u2192</a>\n</div>\n      <div style=\"background:#FFFFFF;border:1px solid rgba(0,0,0,0.07);border-radius:4px;padding:2.5rem 2rem;display:flex;flex-direction:column;position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;top:0;left:0;right:0;height:3px;background:#C49A2A;\"></div>\n  <span style=\"display:inline-block;font-family:DM Mono;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;background:rgba(8,18,42,0.05);border:1px solid rgba(8,18,42,0.1);padding:3px 10px;border-radius:2px;margin-bottom:1.2rem;\">Growth Stage</span>\n  <h3 style=\"font-family:Cormorant Garamond;font-size:1.7rem;font-weight:700;color:#08122A;margin:0 0 0.8rem;line-height:1.15;\">Accelerator</h3>\n  <p style=\"font-size:13px;line-height:1.7;color:#7A8BA8;margin:0 0 1.5rem;flex:1;\">For health & wellness startups ready to scale \u2014 with market access, investor networks, and international exposure.</p>\n  <ul style=\"list-style:none;padding:0;margin:0 0 2rem;\"><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 Scale-ready startups</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 Demo days & investor pitches</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 Go-to-market strategy</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 Corporate partnerships</li></ul>\n  <a href=\"/programs/accelerator/\" style=\"font-size:13px;font-weight:600;color:#C49A2A;text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-top:auto;\">Explore Track \u2192</a>\n</div>\n      <div style=\"background:#FFFFFF;border:1px solid rgba(0,0,0,0.07);border-radius:4px;padding:2.5rem 2rem;display:flex;flex-direction:column;position:relative;overflow:hidden;\">\n  <div style=\"position:absolute;top:0;left:0;right:0;height:3px;background:#C49A2A;\"></div>\n  <span style=\"display:inline-block;font-family:DM Mono;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;background:rgba(8,18,42,0.05);border:1px solid rgba(8,18,42,0.1);padding:3px 10px;border-radius:2px;margin-bottom:1.2rem;\">Unique Differentiator</span>\n  <h3 style=\"font-family:Cormorant Garamond;font-size:1.7rem;font-weight:700;color:#08122A;margin:0 0 0.8rem;line-height:1.15;\">Ayush Incubation</h3>\n  <p style=\"font-size:13px;line-height:1.7;color:#7A8BA8;margin:0 0 1.5rem;flex:1;\">Scientifically validating traditional medicine \u2014 where Ayurveda meets rigorous research, IP protection, and global market access.</p>\n  <ul style=\"list-style:none;padding:0;margin:0 0 2rem;\"><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 Herbal products & formulations</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 AYUSH & WHO compliance</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 IP protection & patents</li><li style=\"font-size:13px;padding:5px 0 5px 0;border-bottom:1px solid rgba(255,255,255,0.06) if False else rgba(0,0,0,0.05);color:#1B2A4A;\">\u2022 Global nutraceutical market</li></ul>\n  <a href=\"/programs/ayush/\" style=\"font-size:13px;font-weight:600;color:#C49A2A;text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-top:auto;\">Explore Track \u2192</a>\n</div>\n    </div>\n  </div>\n</div>"
            },
