          {
            "id": "j71jbb9",
            "elType": "widget",
            "widgetType": "html",
            "settings": {
              "html": "<div id=\"bmiil-header-root\" style=\"font-family:'DM Sans',sans-serif;position:sticky;top:0;left:0;right:0;z-index:9999;\">\n\n<!-- \u2550\u2550\u2550 NAV ROW \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n<nav id=\"bmiil-nav\" style=\"background:#08122A;height:70px;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;border-bottom:1px solid rgba(196,154,42,0.15);overflow:visible;\">\n\n  <!-- LOGO -->\n  <a href=\"/\" style=\"display:flex;align-items:center;gap:12px;text-decoration:none;flex-shrink:0;\">\n    <img src=\"https://test.bmiil.com/wp-content/uploads/2026/05/BMIIL-LOGO.png\"\n         alt=\"BMIIL\" style=\"width:52px;height:52px;object-fit:contain;display:block;flex-shrink:0;\">\n    <div style=\"display:flex;flex-direction:column;line-height:1;\">\n      <strong style=\"font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:700;color:#FFFFFF;letter-spacing:0.04em;line-height:1.2;\">BMIIL</strong>\n      <span style=\"font-family:'DM Mono',monospace;font-size:0.48rem;color:#C49A2A;letter-spacing:0.15em;text-transform:uppercase;margin-top:2px;\">Medtech Incubation</span>\n    </div>\n  </a>\n\n  <!-- DESKTOP MENU SLOT (filled by wp_footer JS injection) -->\n  <div id=\"bmiil-desktop-slot\" style=\"display:flex;align-items:center;\">\n    <!-- Fallback static links shown until WP menu loads -->\n    <ul id=\"bmiil-static-nav\" class=\"bmiil-nav-menu\" style=\"display:flex;align-items:center;gap:2rem;list-style:none;margin:0;padding:0;\">\n      <li><a href=\"/programs/\">Programs</a></li>\n      <li><a href=\"/about/\">About BIU</a></li>\n      <li><a href=\"/team/\">Team</a></li>\n      <li><a href=\"/news/\">News &amp; Events</a></li>\n      <li class=\"nav-cta\"><a href=\"https://test.bmiil.com/investor-deck/\">Investor Deck &#8594;</a></li>\n    </ul>\n  </div>\n\n  <!-- HAMBURGER (mobile) -->\n  <button id=\"bmiil-hamburger\" onclick=\"bmiilToggleMenu()\" aria-label=\"Menu\" aria-expanded=\"false\"\n    style=\"display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;\">\n    <span style=\"display:block;width:24px;height:2px;background:#FFFFFF;border-radius:1px;\"></span>\n    <span style=\"display:block;width:24px;height:2px;background:#FFFFFF;border-radius:1px;\"></span>\n    <span style=\"display:block;width:24px;height:2px;background:#FFFFFF;border-radius:1px;\"></span>\n  </button>\n</nav>\n\n<!-- \u2550\u2550\u2550 ANNOUNCEMENT BAR \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n<div id=\"bmiil-announce\" style=\"background:#C49A2A;padding:0.5rem 2.5rem;display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap;\">\n  <p style=\"font-size:12px;font-weight:500;color:#08122A;letter-spacing:0.03em;margin:0;text-align:center;\">\n    &#127945; <strong>Cohort 1 Applications Open</strong> &#8212; Limited seats available for our inaugural Medtech Incubation Program.\n  </p>\n  <a href=\"https://test.bmiil.com/apply/\" style=\"font-size:12px;font-weight:700;color:#08122A;text-decoration:underline;white-space:nowrap;\">Apply Before August 31 &#8594;</a>\n  <button onclick=\"document.getElementById('bmiil-announce').style.display='none'\"\n    style=\"background:none;border:none;cursor:pointer;color:#08122A;font-size:1rem;opacity:0.6;padding:0;line-height:1;flex-shrink:0;\">&#10005;</button>\n</div>\n\n<!-- \u2550\u2550\u2550 MOBILE MENU \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n<div id=\"bmiil-mobile-menu\" style=\"display:none;background:rgba(8,18,42,0.98);border-bottom:1px solid rgba(196,154,42,0.15);padding:1.2rem 2.5rem 1.8rem;\">\n  <div id=\"bmiil-mobile-slot\">\n    <ul style=\"list-style:none;margin:0;padding:0;\">\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/programs/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">Programs</a></li>\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/about/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">About BIU</a></li>\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/team/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">Team</a></li>\n      <li style=\"border-bottom:1px solid rgba(255,255,255,0.07);\"><a href=\"/news/\" style=\"display:block;padding:0.8rem 0;font-size:15px;color:rgba(255,255,255,0.8);text-decoration:none;\">News &amp; Events</a></li>\n      <li style=\"padding-top:1rem;\"><a href=\"https://test.bmiil.com/investor-deck/\" style=\"background:#C49A2A;color:#08122A;font-weight:600;padding:10px 22px;border-radius:2px;text-decoration:none;display:inline-block;\">Investor Deck &#8594;</a></li>\n    </ul>\n  </div>\n</div>\n\n</div><!-- #bmiil-header-root -->\n\n<!-- \u2550\u2550\u2550 STYLES \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n<style>\n/* Nav menu */\n.bmiil-nav-menu { display:flex!important; align-items:center; gap:2rem; list-style:none!important; margin:0!important; padding:0!important; }\n.bmiil-nav-menu > li { position:relative; list-style:none!important; }\n.bmiil-nav-menu > li > a {\n  font-family:'DM Sans',sans-serif; font-size:13px; color:rgba(255,255,255,0.65)!important;\n  text-decoration:none!important; letter-spacing:0.05em; white-space:nowrap;\n  display:block; padding:0; line-height:70px; background:none!important; transition:color .2s;\n}\n.bmiil-nav-menu > li > a:hover { color:#E2BF68!important; }\n.bmiil-nav-menu > li.current-menu-item > a,\n.bmiil-nav-menu > li.current-page-ancestor > a { color:#C49A2A!important; }\n\n/* CTA button */\n.bmiil-nav-menu > li:last-child > a,\n.bmiil-nav-menu > li.nav-cta > a {\n  background:#C49A2A!important; color:#08122A!important; font-weight:600;\n  padding:8px 22px!important; border-radius:2px; letter-spacing:0.04em; line-height:normal;\n}\n.bmiil-nav-menu > li:last-child > a:hover,\n.bmiil-nav-menu > li.nav-cta > a:hover { background:#E2BF68!important; }\n\n/* Dropdown arrow */\n.bmiil-nav-menu > li.menu-item-has-children > a::after { content:\" \u25be\"; font-size:9px; opacity:0.4; margin-left:2px; }\n\n/* Dropdown panel */\n.bmiil-nav-menu > li > .sub-menu, .bmiil-nav-menu > li > ul {\n  visibility:hidden; opacity:0; pointer-events:none;\n  position:absolute; top:100%; left:0; z-index:10000;\n  min-width:220px; background:#0F1F45;\n  border:1px solid rgba(196,154,42,0.25); border-top:2px solid #C49A2A;\n  border-radius:0 4px 4px 4px; padding:6px 0;\n  box-shadow:0 12px 40px rgba(0,0,0,0.6);\n  list-style:none!important; margin:0;\n  transition:opacity .15s,visibility .15s,transform .15s;\n  transform:translateY(4px);\n}\n.bmiil-nav-menu > li > .sub-menu::before, .bmiil-nav-menu > li > ul::before {\n  content:\"\"; position:absolute; top:-12px; left:0; right:0; height:12px; background:transparent;\n}\n.bmiil-nav-menu > li:hover > .sub-menu,\n.bmiil-nav-menu > li:hover > ul,\n.bmiil-nav-menu > li:focus-within > .sub-menu,\n.bmiil-nav-menu > li:focus-within > ul {\n  visibility:visible; opacity:1; pointer-events:auto; transform:translateY(0);\n}\n.bmiil-nav-menu .sub-menu li, .bmiil-nav-menu > li > ul li { list-style:none!important; border-bottom:1px solid rgba(255,255,255,0.05); }\n.bmiil-nav-menu .sub-menu li:last-child, .bmiil-nav-menu > li > ul li:last-child { border-bottom:none; }\n.bmiil-nav-menu .sub-menu li a, .bmiil-nav-menu > li > ul li a {\n  font-family:'DM Sans',sans-serif!important; font-size:13px!important;\n  color:rgba(255,255,255,0.65)!important; background:transparent!important;\n  padding:11px 20px!important; display:block; white-space:nowrap;\n  letter-spacing:0.03em; font-weight:400!important; line-height:normal;\n  text-decoration:none!important; transition:background .12s,color .12s,padding-left .12s;\n}\n.bmiil-nav-menu .sub-menu li a:hover, .bmiil-nav-menu > li > ul li a:hover {\n  color:#E2BF68!important; background:rgba(196,154,42,0.1)!important; padding-left:26px!important;\n}\n\n/* Scroll effect */\n#bmiil-nav.scrolled { background:rgba(8,18,42,0.99)!important; }\n\n/* Mobile */\n@media(max-width:900px){\n  #bmiil-desktop-slot { display:none!important; }\n  #bmiil-hamburger { display:flex!important; }\n  .bmiil-nav-menu { flex-direction:column!important; gap:0!important; align-items:flex-start!important; }\n  .bmiil-nav-menu > li { width:100%; }\n  .bmiil-nav-menu > li > a { padding:0.8rem 0!important; font-size:15px!important; line-height:normal!important; color:rgba(255,255,255,0.8)!important; border-bottom:1px solid rgba(255,255,255,0.07); }\n  .bmiil-nav-menu > li > .sub-menu, .bmiil-nav-menu > li > ul {\n    position:static!important; visibility:hidden; opacity:0; max-height:0; overflow:hidden;\n    transform:none!important; box-shadow:none!important; border:none!important;\n    border-left:2px solid rgba(196,154,42,0.3)!important; border-radius:0!important;\n    margin:0 0 0 1rem; background:rgba(255,255,255,0.03)!important;\n    transition:opacity .2s,max-height .25s,visibility .2s; padding:0!important;\n  }\n  .bmiil-nav-menu > li.open > .sub-menu, .bmiil-nav-menu > li.open > ul {\n    visibility:visible!important; opacity:1!important; max-height:400px!important; pointer-events:auto!important;\n  }\n  .bmiil-nav-menu > li:hover > .sub-menu, .bmiil-nav-menu > li:hover > ul { visibility:hidden; opacity:0; pointer-events:none; }\n  .bmiil-nav-menu > li.open > .sub-menu, .bmiil-nav-menu > li.open > ul { visibility:visible!important; opacity:1!important; pointer-events:auto!important; }\n}\n</style>\n\n<!-- \u2550\u2550\u2550 JAVASCRIPT \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n<script>\n(function(){\n  /* Inject WP menu from wp_footer hidden div */\n  function injectMenu(){\n    var src = document.getElementById('bmiil-nav-data');\n    if(!src) return;\n    var menu = src.querySelector('ul.bmiil-nav-menu');\n    if(!menu) return;\n    var slot = document.getElementById('bmiil-desktop-slot');\n    if(slot){\n      var fb = document.getElementById('bmiil-static-nav');\n      if(fb) fb.style.display='none';\n      slot.appendChild(menu.cloneNode(true));\n    }\n    var ms = document.getElementById('bmiil-mobile-slot');\n    if(ms){ ms.innerHTML=''; ms.appendChild(menu.cloneNode(true)); }\n    /* Highlight current page */\n    var path = window.location.pathname;\n    document.querySelectorAll('.bmiil-nav-menu a').forEach(function(a){\n      var h = a.getAttribute('href')||'';\n      if(h!=='/' && h!=='' && path.indexOf(h)===0) a.style.color='#C49A2A';\n    });\n  }\n  /* Mobile toggle */\n  window.bmiilToggleMenu = function(){\n    var m = document.getElementById('bmiil-mobile-menu');\n    var open = m.style.display==='block';\n    m.style.display = open?'none':'block';\n    document.getElementById('bmiil-hamburger').setAttribute('aria-expanded',String(!open));\n  };\n  /* Mobile dropdown tap */\n  function initMobile(){\n    if(window.innerWidth>900) return;\n    document.querySelectorAll('.bmiil-nav-menu>li.menu-item-has-children>a').forEach(function(a){\n      a.addEventListener('click',function(e){\n        var li=this.closest('li'), isOpen=li.classList.contains('open');\n        document.querySelectorAll('.bmiil-nav-menu>li').forEach(function(el){el.classList.remove('open');});\n        if(!isOpen){e.preventDefault();li.classList.add('open');}\n      });\n    });\n  }\n  /* Close dropdown outside click */\n  document.addEventListener('click',function(e){\n    if(!e.target.closest('.bmiil-nav-menu'))\n      document.querySelectorAll('.bmiil-nav-menu>li').forEach(function(el){el.classList.remove('open');});\n  });\n  /* Scroll effect */\n  window.addEventListener('scroll',function(){\n    var n=document.getElementById('bmiil-nav');\n    if(n) n.style.background=window.scrollY>10?'rgba(8,18,42,0.99)':'#08122A';\n  },{passive:true});\n  /* Init */\n  if(document.readyState==='loading'){\n    document.addEventListener('DOMContentLoaded',function(){injectMenu();initMobile();});\n  }else{injectMenu();initMobile();}\n})();\n</script>"
            }
          }
        ]
      }
    ]
  }
]