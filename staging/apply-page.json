            "id": "q2ecdtw",
            "elType": "widget",
            "widgetType": "html",
            "settings": {
              "html": "<div style=\"background:#F7F3EC;padding:7rem 0;\">\n  <div style=\"max-width:1220px;margin:0 auto;padding:0 2.5rem;\">\n    <div style=\"display:grid;grid-template-columns:1fr 2fr;gap:5rem;align-items:start;\">\n\n      <!-- Left sidebar info -->\n      <div style=\"position:sticky;top:120px;\">\n        <p style=\"display:inline-block;font-family:DM Mono;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#C49A2A;border:1px solid rgba(196,154,42,0.25);padding:4px 12px;border-radius:2px;background:rgba(196,154,42,0.08);margin:0 0 1.2rem;\">Apply for Incubation</p>\n        <h2 style=\"font-family:Cormorant Garamond;font-size:2.2rem;font-weight:300;color:#08122A;margin:0 0 1rem;line-height:1.2;\">Join BMIIL's <strong style=\"font-weight:700;\">Cohort 1</strong></h2>\n        <p style=\"font-size:14px;line-height:1.8;color:#4A5C78;margin:0 0 2rem;\">Fill this form to apply for incubation. All required fields are marked <span style=\"color:#C49A2A;\">*</span>. Applications are reviewed on a rolling basis.</p>\n        <div style=\"display:flex;flex-direction:column;gap:1rem;\">\n          <div style=\"background:#08122A;border-radius:4px;padding:1.5rem;\">\n            <div style=\"font-family:DM Mono;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:#C49A2A;margin-bottom:0.6rem;\">Applications Close</div>\n            <div style=\"font-family:Cormorant Garamond;font-size:1.4rem;font-weight:700;color:#FFFFFF;\">August 31, 2026</div>\n          </div>\n          <div style=\"background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:1.5rem;\">\n            <div style=\"font-family:DM Mono;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:#7A8BA8;margin-bottom:0.6rem;\">Questions?</div>\n            <a href=\"mailto:info@bmiil.com\" style=\"font-size:14px;font-weight:600;color:#C49A2A;text-decoration:none;\">info@bmiil.com</a>\n          </div>\n        </div>\n      </div>\n\n      <!-- Right: form -->\n      <form method=\"post\" enctype=\"multipart/form-data\"\n            action=\"https://formsubmit.co/info@bmiil.com\"\n            style=\"display:flex;flex-direction:column;gap:1.5rem;background:#FFFFFF;border:1px solid #EDE8DE;border-radius:4px;padding:2.5rem;\">\n\n        <!-- FormSubmit config fields -->\n        <input type=\"hidden\" name=\"_subject\" value=\"New BMIIL Incubation Application\">\n        <input type=\"hidden\" name=\"_next\" value=\"https://test.bmiil.com/apply-now/?submitted=true\">\n        <input type=\"hidden\" name=\"_captcha\" value=\"false\">\n        <input type=\"hidden\" name=\"_template\" value=\"table\">\n\n        <h3 style=\"font-family:Cormorant Garamond;font-size:1.5rem;font-weight:700;color:#08122A;margin:0;border-bottom:1px solid #EDE8DE;padding-bottom:1rem;\">Startup Information</h3>\n\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Startup Name <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"startup_name\" required placeholder=\"Your startup name\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Founder's Name <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"founder_name\" required placeholder=\"Full name\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n        </div>\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Designation <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"designation\" required placeholder=\"e.g. CEO, Co-founder\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Email Address <span style=\"color:#C49A2A;\">*</span></label><input type=\"email\" name=\"email\" required placeholder=\"your@email.com\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n        </div>\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Phone / WhatsApp <span style=\"color:#C49A2A;\">*</span></label><input type=\"tel\" name=\"phone\" required placeholder=\"+91 00000 00000\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Website / Social Media</label><input type=\"text\" name=\"website\"  placeholder=\"https://\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n        </div>\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">City & State of Operation <span style=\"color:#C49A2A;\">*</span></label><input type=\"text\" name=\"city_state\" required placeholder=\"e.g. Bareilly, Uttar Pradesh\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Preferred Mode of Incubation <span style=\"color:#C49A2A;\">*</span></label><select name=\"mode_of_incubation\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"Physical (On-Site at BMIIL)\">Physical (On-Site at BMIIL)</option><option value=\"Virtual / Remote\">Virtual / Remote</option><option value=\"Hybrid\">Hybrid</option></select></div>\n        </div>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Brief Description of Your Startup (100\u2013200 words) <span style=\"color:#C49A2A;\">*</span></label><textarea name=\"brief_description\" required placeholder=\"Brief Description of Your Startup (100\u2013200 words)\" rows=\"4\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;resize:vertical;outline:none;\"></textarea></div>\n\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Sector / Domain <span style=\"color:#C49A2A;\">*</span></label><select name=\"sector\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"MedTech\">MedTech</option><option value=\"HealthTech\">HealthTech</option><option value=\"Ayurveda / Wellness\">Ayurveda / Wellness</option><option value=\"Biomedical Devices\">Biomedical Devices</option><option value=\"Diagnostics\">Diagnostics</option><option value=\"AI / Data in Healthcare\">AI / Data in Healthcare</option><option value=\"Other\">Other</option></select></div>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Year of Incorporation / Registration</label><input type=\"text\" name=\"year_of_incorporation\"  placeholder=\"e.g. 2024\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n        </div>\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Team Size <span style=\"color:#C49A2A;\">*</span></label><select name=\"team_size\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"1-3\">1-3</option><option value=\"4-10\">4-10</option><option value=\"11-25\">11-25</option><option value=\"25+\">25+</option></select></div>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Do You Have a Prototype / MVP? <span style=\"color:#C49A2A;\">*</span></label><select name=\"prototype_mvp\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"Yes\">Yes</option><option value=\"No\">No</option><option value=\"Under Development\">Under Development</option></select></div>\n        </div>\n\n        <h3 style=\"font-family:Cormorant Garamond;font-size:1.5rem;font-weight:700;color:#08122A;margin:0.5rem 0 0;border-bottom:1px solid #EDE8DE;padding-bottom:1rem;\">Your Innovation</h3>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">What Problem Are You Solving? <span style=\"color:#C49A2A;\">*</span></label><textarea name=\"problem_statement\" required placeholder=\"What Problem Are You Solving?\" rows=\"4\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;resize:vertical;outline:none;\"></textarea></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">What Is Innovative About Your Solution? <span style=\"color:#C49A2A;\">*</span></label><textarea name=\"innovation\" required placeholder=\"What Is Innovative About Your Solution?\" rows=\"4\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;resize:vertical;outline:none;\"></textarea></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">What Makes Your Startup Unique (USP)?</label><textarea name=\"usp\"  placeholder=\"What Makes Your Startup Unique (USP)?\" rows=\"4\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;resize:vertical;outline:none;\"></textarea></div>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Are you using Ayurvedic / indigenous knowledge-based innovation?</label><div style=\"display:flex;gap:2rem;padding:10px 14px;border:1px solid #EDE8DE;border-radius:2px;background:#FFFFFF;\"><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"radio\" name=\"ayurvedic_innovation\" value=\"Yes\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Yes</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"radio\" name=\"ayurvedic_innovation\" value=\"No\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> No</label></div></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Have You Conducted Any Clinical Validation or Testing? <span style=\"color:#C49A2A;\">*</span></label><select name=\"clinical_validation\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"Yes\">Yes</option><option value=\"No\">No</option></select></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Any Existing Partnerships or Customers?</label><input type=\"text\" name=\"partnerships\"  placeholder=\"Describe any existing partnerships or customers\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;\" /></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Funding Status <span style=\"color:#C49A2A;\">*</span></label><select name=\"funding_status\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"Bootstrapped\">Bootstrapped</option><option value=\"Angel Funded\">Angel Funded</option><option value=\"Grant Received\">Grant Received</option><option value=\"Seeking Funding\">Seeking Funding</option></select></div>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">What Kind of Support Are You Looking For?</label><div style=\"display:flex;flex-direction:column;gap:6px;padding:10px 14px;border:1px solid #EDE8DE;border-radius:2px;background:#FFFFFF;\"><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Infrastructure / Lab Access\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Infrastructure / Lab Access</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Regulatory Guidance\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Regulatory Guidance</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Business Development Support\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Business Development Support</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Ayurvedic Research Collaboration\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Ayurvedic Research Collaboration</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Mentorship\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Mentorship</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Funding / Investor Connect\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Funding / Investor Connect</label><label style=\"display:flex;align-items:center;gap:8px;font-size:14px;color:#08122A;cursor:pointer;\"><input type=\"checkbox\" name=\"support_needed[]\" value=\"Clinical Trial Support\" style=\"width:16px;height:16px;accent-color:#C49A2A;\"> Clinical Trial Support</label></div></div>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">How Did You Hear About BMIIL? <span style=\"color:#C49A2A;\">*</span></label><select name=\"source\" required style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:14px;color:#08122A;background:#FFFFFF;font-family:DM Sans;outline:none;appearance:auto;\"><option value=\"\">-- Select --</option><option value=\"University / College\">University / College</option><option value=\"Startup Event\">Startup Event</option><option value=\"Online / Social Media\">Online / Social Media</option><option value=\"Referral\">Referral</option><option value=\"Other\">Other</option></select></div>\n\n        <h3 style=\"font-family:Cormorant Garamond;font-size:1.5rem;font-weight:700;color:#08122A;margin:0.5rem 0 0;border-bottom:1px solid #EDE8DE;padding-bottom:1rem;\">Documents</h3>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Upload Pitch Deck</label><input type=\"file\" name=\"pitch_deck\" accept=\".pdf\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:13px;color:#7A8BA8;background:#FFFFFF;font-family:DM Sans;\" /><span style=\"font-size:11px;color:#7A8BA8;\">PDF only, max 10MB</span></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Upload Company Registration / Proof (optional)</label><input type=\"file\" name=\"company_registration\" accept=\".pdf\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:13px;color:#7A8BA8;background:#FFFFFF;font-family:DM Sans;\" /><span style=\"font-size:11px;color:#7A8BA8;\">PDF only, max 10MB</span></div>\n        <div style=\"display:flex;flex-direction:column;gap:6px;\"><label style=\"font-family:DM Mono;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#7A8BA8;\">Upload Any Additional Document (optional)</label><input type=\"file\" name=\"additional_doc\" accept=\".pdf,.doc,.docx\" style=\"border:1px solid #EDE8DE;border-radius:2px;padding:10px 14px;font-size:13px;color:#7A8BA8;background:#FFFFFF;font-family:DM Sans;\" /><span style=\"font-size:11px;color:#7A8BA8;\">PDF only, max 10MB</span></div>\n\n        <!-- Declaration -->\n        <div style=\"background:#F7F3EC;border-radius:4px;padding:1.2rem;border-left:3px solid #C49A2A;\">\n          <label style=\"display:flex;align-items:flex-start;gap:10px;font-size:13px;color:#4A5C78;line-height:1.6;cursor:pointer;\">\n            <input type=\"checkbox\" name=\"declaration\" required style=\"width:16px;height:16px;margin-top:2px;accent-color:#C49A2A;flex-shrink:0;\">\n            <span>I hereby declare that all the information provided above is true to the best of my knowledge. I understand that submission of this form does not guarantee selection for incubation at BMIIL.</span>\n          </label>\n        </div>\n\n        <button type=\"submit\"\n          style=\"background:#C49A2A;color:#08122A;font-weight:700;font-size:14px;letter-spacing:0.06em;padding:16px 40px;border-radius:2px;border:none;cursor:pointer;font-family:DM Sans;text-transform:uppercase;width:100%;\">\n          Apply for Incubation &#8594;\n        </button>\n        <p style=\"font-size:12px;color:#7A8BA8;text-align:center;margin:0;\">All form submissions are sent directly to <strong>info@bmiil.com</strong></p>\n      </form>\n\n    </div>\n  </div>\n</div>"
